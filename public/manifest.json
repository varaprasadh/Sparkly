{
    "version": "4.2.0",
    "manifest_version": 3,
    "name": "Sparkly: New Tab",
    "description": "New tab page with cool HD backgrounds!",
    "icons": {
        "128": "./images/icon.png",
        "48": "./images/icon.png",
        "16": "./images/icon.png"
    },
    "action": {
        "default_icon": {
            "128": "./images/icon.png",
            "48": "./images/icon.png",
            "16": "./images/icon.png"
        }
    },
    "chrome_url_overrides": {
        "newtab": "./new-tab.html"
    },
    "background": {
        "service_worker": "./background.js"
    },
    "web_accessible_resources": [
        {
            "resources": ["images/icon.png"],
            "matches": [
                "<all_urls>"
            ]
        }
    ],
    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'self'; img-src *"
    },
    "permissions": [
        "topSites",
        "storage",
        "unlimitedStorage"
    ],
    "host_permissions":[
        "http://*/*",
        "https://*/*"
    ]
}