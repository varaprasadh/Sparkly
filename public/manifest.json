{
    "key": "",
    "version": "4.4.5",
    "version_name": "4.4.5",
    "manifest_version": 3,
    "name": "Sparkly: New Tab for Productive People",
    "description": "Replace your new tab with a beautiful dashboard — wallpapers, news feed, tab manager, and search — all in one place.",
    "icons": {
        "16": "images/icon-16.png",
        "48": "images/icon-48.png",
        "128": "images/icon-128.png"
    },
    "action": {
        "default_icon": {
            "16": "images/icon-16.png",
            "48": "images/icon-48.png",
            "128": "images/icon-128.png"
        }
    },
    "chrome_url_overrides": {
        "newtab": "./new-tab.html"
    },
    "background": {
        "service_worker": "./background.js"
    },
    "oauth2": {
        "client_id": "313065344975-k6uda6csaampc8g7i98qpoko9q7fmcr7.apps.googleusercontent.com",
        "scopes": [
            "https://www.googleapis.com/auth/userinfo.email",
            "https://www.googleapis.com/auth/userinfo.profile",
            "https://www.googleapis.com/auth/calendar.readonly",
            "https://www.googleapis.com/auth/drive.readonly",
            "https://www.googleapis.com/auth/gmail.readonly"
        ]
    },
    "web_accessible_resources": [
        {
            "resources": ["images/icon-16.png", "images/icon-48.png", "images/icon-128.png"],
            "matches": [
                "<all_urls>"
            ]
        }
    ],
    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'self'; img-src * data:"
    },
    "permissions": [
        "topSites",
        "storage",
        "unlimitedStorage",
        "tabs",
        "sessions",
        "identity"
    ],
    "host_permissions":[
        "http://*/*",
        "https://*/*"
    ]
}